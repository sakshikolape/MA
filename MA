AuthService.java 
package com.example.auth_service.service; 
 
import com.example.auth_service.model.LoginRequest; 
import org.springframework.stereotype.Service; 
import org.springframework.web.client.RestTemplate; 
@Service 
public class AuthService { 
    public String login(LoginRequest request) { 
        RestTemplate restTemplate = new RestTemplate(); 
        String url = "http://localhost:8081/user/" + request.getUsername(); 
        try { 
            Object user = restTemplate.getForObject(url, Object.class); 
            if(user != null && request.getPassword().equals("1234")) { 
                return "Login Successful"; 
            } 
        } catch(Exception e) { 
            return "User Not Found"; 
        } 
        return "Invalid Password"; 
    } 
}

AuthController.java 
package com.example.auth_service.controller; 
 
import com.example.auth_service.model.LoginRequest; 
import com.example.auth_service.service.AuthService; 
