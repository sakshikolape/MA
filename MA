resilience4j.circuitbreaker.instances.demoService.failureRateThreshold=50 
resilience4j.circuitbreaker.instances.demoService.slidingWindowSize=5 
resilience4j.circuitbreaker.instances.demoService.waitDurationInOpenState=10s 
